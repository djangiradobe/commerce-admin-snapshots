# Compiled TypeScript output — generated by `npm run build` (tsc + esbuild).
# Sources are the .ts/.tsx; never commit the emitted .js. Regenerated on
# `npm install` (prepare) and before publish. The hand-written web/index.js
# re-export shim is NOT under these paths, so it stays committed.
/src/**/*.js
/actions/**/*.js
/scripts/**/*.js
/web/dist/
node_modules/
